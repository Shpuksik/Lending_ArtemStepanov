{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lending-artemstepanov",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-14",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "ai-neuro.ru",
      "zone_name": "ai-neuro.ru",
      "custom_domain": true
    }
  ]
}