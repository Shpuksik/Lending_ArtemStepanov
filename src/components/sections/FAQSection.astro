---
import { faq } from '../../config/content';
---

<section class="py-16 md:py-24 max-w-[1200px] mx-auto px-5 lg:px-8">
  <h2 class="text-2xl md:text-4xl font-medium mb-10 text-text-main" data-reveal>FAQ</h2>
  
  <div class="max-w-3xl" data-reveal-group>
    {faq.map((item) => (
      <details class="group border-b border-border py-5 cursor-pointer" data-reveal-item>
        <summary class="flex justify-between items-center font-medium text-base md:text-lg text-text-main outline-none select-none">
          {item.question}
          <span class="transition-transform duration-300 group-open:rotate-45 text-text-muted text-xl ml-4 font-light">
            +
          </span>
        </summary>
        <div class="mt-4 text-text-secondary text-sm md:text-base pr-8 leading-relaxed">
          {item.answer}
        </div>
      </details>
    ))}
  </div>
</section>
