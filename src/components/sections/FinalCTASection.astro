---
import Button from '../ui/Button.astro';
import { contacts } from '../../config/content';
---

<section id="contacts" class="py-16 md:py-32 w-full bg-surface border-y border-border">
  <div class="max-w-[1200px] mx-auto px-5 lg:px-8 text-center max-w-2xl mx-auto" data-reveal>
    <h2 class="text-2xl md:text-4xl font-medium mb-6 text-text-main">Готовы навести порядок?</h2>
    
    <p class="text-base md:text-lg text-text-secondary leading-relaxed mb-10">
      Если в вашем бизнесе есть ручная рутина и процессы, которые отнимают слишком много времени — их стоит хотя бы разобрать. Напишите мне, и мы обсудим вашу задачу.
    </p>
    
    <div class="flex flex-col items-center gap-6">
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <Button href={contacts.telegram} variant="primary" class="w-full sm:w-auto text-base">
          Написать в Telegram
        </Button>
        <Button href={contacts.max} variant="primary" class="w-full sm:w-auto text-base">
          Написать в MAX
        </Button>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 sm:gap-8 text-sm">
        <a href={`tel:${contacts.phone.replace(/[^+\d]/g, '')}`} class="text-text-secondary hover:text-text-main transition-colors">{contacts.phone}</a>
      </div>
    </div>
  </div>
</section>
