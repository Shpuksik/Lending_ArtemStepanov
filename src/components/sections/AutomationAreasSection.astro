---
import Card from '../ui/Card.astro';
import { automationAreas } from '../../config/content';
---

<section class="py-16 md:py-24 max-w-[1200px] mx-auto px-5 lg:px-8">
  <div class="mb-12 max-w-3xl" data-reveal>
    <h2 class="text-2xl md:text-4xl font-medium mb-4 text-text-main">Что можно передать автоматизации</h2>
    <p class="text-base md:text-lg text-text-secondary">
      Сначала мы смотрим на сам процесс: где теряется время, где появляются ошибки и какие действия повторяются чаще всего. После этого становится понятно, что действительно стоит автоматизировать.
    </p>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal-group>
    {automationAreas.map((area, index) => (
      <Card class={`flex flex-col h-full ${index < 3 ? 'border-t-2 border-t-accent/50' : ''}`} data-reveal-item>
        <div class="text-text-muted text-[13px] font-medium mb-4">0{index + 1}</div>
        <h3 class="text-[17px] font-medium text-text-main mb-3">{area.title}</h3>
        <p class="text-[15px] text-text-secondary mb-6 flex-grow leading-relaxed">{area.description}</p>
        <div class="text-[14px] text-text-secondary mt-auto pt-4 border-t border-border/50">
          <span>{area.effect}</span>
        </div>
      </Card>
    ))}
  </div>
</section>
