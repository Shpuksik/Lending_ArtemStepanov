---
import Card from '../ui/Card.astro';
import { cases } from '../../config/content';
---

<section class="py-16 md:py-24 max-w-[1200px] mx-auto px-5 lg:px-8">
  <h2 class="text-2xl md:text-4xl font-medium mb-12 text-text-main" data-reveal>Проекты из практики</h2>
  
  <div class="flex flex-wrap justify-center gap-6" data-reveal-group>
    {cases.map((c) => (
      <div class="w-full lg:basis-[calc(50%-12px)] min-w-0">
        <Card class="flex flex-col h-full" data-reveal-item>
        <div class="mb-4">
          <span class="text-[12px] font-medium uppercase tracking-wider text-accent border border-accent/20 bg-accent/5 px-2 py-1 rounded">Кейс</span>
        </div>
        <h3 class="text-[18px] font-medium text-text-main mb-6 pb-4 border-b border-border/50">{c.title}</h3>
        
        <div class="space-y-4 flex-grow text-[15px]">
          <div>
            <span class="text-text-muted font-medium block mb-1">Контекст:</span>
            <span class="text-text-secondary">{c.context}</span>
          </div>
          <div>
            <span class="text-text-muted font-medium block mb-1">Проблема:</span>
            <span class="text-text-secondary">{c.problem}</span>
          </div>
          <div>
            <span class="text-text-muted font-medium block mb-1">Решение:</span>
            <span class="text-text-secondary">{c.solution}</span>
          </div>
          <div class="pt-2">
            <span class="text-accent opacity-90 font-medium block mb-1">Результат:</span>
            <span class="text-text-main">{c.result}</span>
          </div>
          {c.links && (
            <div class="mt-6 pt-4 border-t border-border/50 flex flex-wrap gap-3">
              {c.links.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-[14px] text-accent hover:text-accent-hover font-medium transition-all py-2 px-3.5 rounded-lg bg-accent/5 hover:bg-accent/10 border border-accent/10 hover:border-accent/20 active:scale-[0.98]"
                >
                  {link.label}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 opacity-80">
                    <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd" />
                  </svg>
                </a>
              ))}
            </div>
          )}
        </div>
      </Card>
      </div>
    ))}
  </div>
</section>
