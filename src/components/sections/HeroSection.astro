---
import Button from '../ui/Button.astro';
import { hero } from '../../config/content';
---

<section class="py-16 md:py-32 max-w-[1200px] mx-auto px-5 lg:px-8 flex flex-col items-start relative">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(56,189,248,0.1),transparent_50%)] pointer-events-none"></div>
  
  <div class="max-w-3xl relative z-10">
    <h1 class="text-3xl md:text-5xl lg:text-6xl font-medium leading-[1.2] md:leading-[1.2] tracking-tight mb-6 text-text-main">
      {hero.h1}
    </h1>
    <p class="text-base md:text-lg text-text-secondary leading-relaxed mb-10 max-w-2xl">
      {hero.subtitle}
    </p>
    
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-4 w-full sm:w-auto">
      <Button href="#contacts" variant="primary" class="w-full sm:w-auto text-base">
        Обсудить задачу
      </Button>
      <Button href="#formats" variant="secondary" class="w-full sm:w-auto text-base">
        Узнать форматы работы
      </Button>
    </div>
    <p class="text-sm text-text-muted">{hero.microtext}</p>
  </div>
</section>
