---
import Button from '../ui/Button.astro';
import HeroDataFlow from '../ui/HeroDataFlow.astro';
import { hero } from '../../config/content';
---

<section class="py-16 md:py-24 lg:py-32 w-full relative overflow-hidden flex justify-center border-b border-border/30">
  <HeroDataFlow />
  
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(56,189,248,0.1),transparent_50%)] pointer-events-none"></div>
  
  <div class="w-full max-w-[1200px] px-5 lg:px-8 relative z-10">
    <div class="max-w-3xl" data-reveal-group>
      <h1 data-reveal-item class="text-[38px] md:text-[44px] lg:text-[64px] font-medium leading-[1.05] tracking-tight mb-6 text-text-main">
        {hero.h1}
      </h1>
      <p data-reveal-item class="text-[16px] md:text-[18px] lg:text-[20px] text-text-secondary leading-relaxed mb-10 max-w-2xl">
        {hero.subtitle}
      </p>
      
      <div data-reveal-item class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-4 w-full sm:w-auto">
        <Button href="#contacts" variant="primary" class="w-full sm:w-auto text-base">
          Обсудить задачу
        </Button>
        <Button href="#formats" variant="secondary" class="w-full sm:w-auto text-base">
          Узнать форматы работы
        </Button>
      </div>
      <p data-reveal-item class="text-sm text-text-muted">{hero.microtext}</p>
    </div>
  </div>
</section>
