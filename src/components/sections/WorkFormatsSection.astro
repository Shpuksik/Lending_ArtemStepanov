---
import Card from '../ui/Card.astro';
import { workFormats } from '../../config/content';
---

<section id="formats" class="py-16 md:py-24 max-w-[1200px] mx-auto px-5 lg:px-8">
  <h2 class="text-2xl md:text-4xl font-medium mb-12 text-text-main">Форматы работы</h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {workFormats.map((format) => (
      <Card class="flex flex-col">
        <h3 class="text-lg font-medium text-text-main mb-3">{format.title}</h3>
        <p class="text-text-secondary mb-6 flex-grow text-sm md:text-base">{format.description}</p>
        <div class="text-sm text-text-muted pt-4 border-t border-border">
          <span class="font-medium">Кому подходит:</span> {format.audience}
        </div>
      </Card>
    ))}
  </div>
</section>
