---
import { about } from '../../config/content';
---

<section class="py-16 md:py-24 max-w-[1200px] mx-auto px-5 lg:px-8">
  <div class="max-w-3xl" data-reveal>
    <div class="text-accent text-5xl md:text-7xl font-bold mb-6 opacity-90 tracking-tighter">15</div>
    
    <div class="space-y-6 text-base md:text-lg text-text-secondary">
      {about.text.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </div>
</section>
