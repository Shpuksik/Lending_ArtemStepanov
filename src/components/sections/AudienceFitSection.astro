---
import { audienceFit } from '../../config/content';
---

<section class="py-16 md:py-24 max-w-[1200px] mx-auto px-5 lg:px-8">
  <h2 class="text-2xl md:text-4xl font-medium mb-12 text-text-main" data-reveal>Кому будет полезен этот подход</h2>
  
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16" data-reveal-group>
    <div data-reveal-item>
      <h3 class="text-xl font-medium text-text-main mb-6">Подходит, если:</h3>
      <ul class="space-y-4">
        {audienceFit.fits.map(item => (
          <li class="flex items-start">
            <span class="text-accent mr-3 mt-1 opacity-70 flex-shrink-0">✓</span>
            <span class="text-base text-text-secondary">{item}</span>
          </li>
        ))}
      </ul>
    </div>
    
    <div data-reveal-item>
      <h3 class="text-xl font-medium text-text-main mb-6">Не подходит, если:</h3>
      <ul class="space-y-4">
        {audienceFit.doesNotFit.map(item => (
          <li class="flex items-start">
            <span class="text-text-muted mr-3 mt-1 flex-shrink-0">—</span>
            <span class="text-base text-text-muted">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
