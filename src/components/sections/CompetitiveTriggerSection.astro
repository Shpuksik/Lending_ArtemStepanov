---
import Button from '../ui/Button.astro';
import { competitiveTrigger, contacts } from '../../config/content';
---

<section class="py-16 md:py-32 w-full bg-surface border-y border-border">
  <div class="max-w-[1200px] mx-auto px-5 lg:px-8 text-center max-w-4xl mx-auto">
    <h2 class="text-2xl md:text-4xl font-medium mb-8 text-text-main">Пока одни присматриваются, другие уже используют</h2>
    
    <div class="text-base md:text-xl text-text-secondary leading-relaxed mb-10 text-left md:text-center whitespace-pre-line max-w-3xl mx-auto">
      {competitiveTrigger.text}
    </div>
    
    <Button href={contacts.telegram} variant="primary" class="w-full sm:w-auto text-base">
      Узнать, как это работает
    </Button>
  </div>
</section>
