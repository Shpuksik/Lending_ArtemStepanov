---
import { processSteps } from '../../config/content';
---

<section class="py-16 md:py-24 max-w-[1200px] mx-auto px-5 lg:px-8">
  <div class="max-w-3xl mb-12">
    <h2 class="text-2xl md:text-4xl font-medium mb-4 text-text-main">Как строится работа</h2>
    <p class="text-base md:text-lg text-text-secondary">
      Внедрение автоматизации — это понятный инженерный процесс. Основной фокус — понять процесс, выделить повторяющиеся действия и аккуратно встроить автоматизацию в работу бизнеса.
    </p>
  </div>

  <div class="relative max-w-3xl">
    <div class="absolute left-[15px] top-4 bottom-4 w-[1px] bg-border md:left-[23px]"></div>
    
    <div class="space-y-8 md:space-y-12">
      {processSteps.map((step, index) => (
        <div class="relative pl-10 md:pl-16">
          <div class="absolute left-0 top-1 w-8 h-8 md:w-12 md:h-12 rounded-full bg-surface border border-border flex items-center justify-center text-xs md:text-sm text-text-muted font-medium z-10">
            0{index + 1}
          </div>
          <h3 class="text-lg font-medium text-text-main mb-2 mt-1 md:mt-3">{step.title}</h3>
          <p class="text-text-secondary text-sm md:text-base">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
