---
// src/components/ui/HeroDataFlow.astro
// Decorative data-flow background for Hero section.
// Strictly contained within parent via absolute inset-0 + overflow-hidden.
---
<div class="hero-dataflow-layer" aria-hidden="true">
  
  <!-- DESKTOP SVG -->
  <svg class="hero-svg hero-svg--desktop" viewBox="0 0 1400 900" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
    <defs>
      <filter id="glow-d" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="8" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
      <filter id="ribbon-blur-1">
        <feGaussianBlur stdDeviation="40" />
      </filter>
      <filter id="ribbon-blur-2">
        <feGaussianBlur stdDeviation="60" />
      </filter>
    </defs>

    <!-- Flow Ribbons (wide, soft cyan glow) -->
    <g opacity="0.9">
      <path d="M-200,600 C300,650 500,200 1100,250 C1300,266 1600,150 1600,150" stroke="#38BDF8" stroke-width="80" filter="url(#ribbon-blur-1)" opacity="0.15" />
      <path d="M-200,750 C400,700 700,800 1200,600 C1400,500 1600,450 1600,450" stroke="#38BDF8" stroke-width="140" filter="url(#ribbon-blur-2)" opacity="0.12" />
    </g>

    <!-- Crisp data lines -->
    <g opacity="0.6">
      <path d="M-200,600 C300,650 500,200 1100,250 C1300,266 1600,150 1600,150" stroke="#38BDF8" stroke-width="1.5" />
      <path d="M-200,680 C400,680 600,350 1000,450 C1300,525 1600,300 1600,300" stroke="#38BDF8" stroke-width="1" />
      <path d="M-200,750 C400,700 700,800 1200,600 C1400,500 1600,450 1600,450" stroke="#38BDF8" stroke-width="1.5" />
      <path d="M200,800 C500,800 800,950 1300,750 C1500,690 1600,800 1600,800" stroke="#38BDF8" stroke-width="1" />
      <!-- Connecting branches -->
      <path d="M600,200 C700,400 650,650 700,800" stroke="#38BDF8" stroke-width="0.5" stroke-dasharray="4 6" opacity="0.7" />
      <path d="M1000,250 C1100,450 1050,650 1200,600" stroke="#38BDF8" stroke-width="0.5" stroke-dasharray="4 6" opacity="0.7" />
      <path d="M800,225 C850,300 850,400 1000,450" stroke="#38BDF8" stroke-width="0.5" stroke-dasharray="4 6" opacity="0.7" />
    </g>

    <!-- Moving impulses -->
    <g filter="url(#glow-d)" opacity="1">
      <path d="M-200,600 C300,650 500,200 1100,250 C1300,266 1600,150 1600,150" stroke="#38BDF8" stroke-width="3" fill="none" class="pulse-d pulse-d-1" />
      <path d="M-200,680 C400,680 600,350 1000,450 C1300,525 1600,300 1600,300" stroke="#38BDF8" stroke-width="3" fill="none" class="pulse-d pulse-d-2" />
      <path d="M-200,750 C400,700 700,800 1200,600 C1400,500 1600,450 1600,450" stroke="#38BDF8" stroke-width="4" fill="none" class="pulse-d pulse-d-3" />
    </g>

    <!-- Connection nodes -->
    <g opacity="0.9">
      <circle cx="500" cy="200" r="4" fill="#38BDF8" filter="url(#glow-d)" />
      <circle cx="1100" cy="250" r="5" fill="#38BDF8" filter="url(#glow-d)" />
      <circle cx="700" cy="800" r="4" fill="#38BDF8" filter="url(#glow-d)" />
      <circle cx="1200" cy="600" r="5" fill="#38BDF8" filter="url(#glow-d)" />
      <circle cx="1000" cy="450" r="4" fill="#38BDF8" filter="url(#glow-d)" />
      <circle cx="600" cy="350" r="3" fill="#38BDF8" opacity="0.6" />
      <circle cx="800" cy="225" r="3" fill="#38BDF8" opacity="0.6" />
    </g>
  </svg>

  <!-- MOBILE SVG -->
  <svg class="hero-svg hero-svg--mobile" viewBox="0 0 400 700" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMaxYMid slice">
    <defs>
      <filter id="glow-m" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="6" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
      <filter id="ribbon-blur-m">
        <feGaussianBlur stdDeviation="30" />
      </filter>
    </defs>

    <!-- Flow ribbons mobile -->
    <g opacity="0.9">
      <path d="M-50,480 C100,480 200,300 450,250" stroke="#38BDF8" stroke-width="50" filter="url(#ribbon-blur-m)" opacity="0.25" />
      <path d="M-50,580 C120,580 250,450 450,350" stroke="#38BDF8" stroke-width="70" filter="url(#ribbon-blur-m)" opacity="0.2" />
    </g>

    <!-- Crisp lines mobile -->
    <g opacity="0.7">
      <path d="M-50,480 C100,480 200,300 450,250" stroke="#38BDF8" stroke-width="1.5" />
      <path d="M-50,530 C110,530 220,380 450,300" stroke="#38BDF8" stroke-width="1" />
      <path d="M-50,580 C120,580 250,450 450,350" stroke="#38BDF8" stroke-width="1.5" />
    </g>

    <!-- Pulses mobile -->
    <g filter="url(#glow-m)" opacity="1">
      <path d="M-50,480 C100,480 200,300 450,250" stroke="#38BDF8" stroke-width="3" fill="none" class="pulse-m pulse-m-1" />
      <path d="M-50,580 C120,580 250,450 450,350" stroke="#38BDF8" stroke-width="3.5" fill="none" class="pulse-m pulse-m-2" />
    </g>

    <!-- Nodes mobile -->
    <g opacity="0.9">
      <circle cx="200" cy="300" r="4" fill="#38BDF8" filter="url(#glow-m)" />
      <circle cx="350" cy="280" r="4" fill="#38BDF8" filter="url(#glow-m)" />
    </g>
  </svg>

</div>

<style>
  /* Layer: fully contained, no overflow possible */
  .hero-dataflow-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Shared SVG rules */
  .hero-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Desktop: shift visual rightward so text area stays clear */
  .hero-svg--desktop {
    display: none;
  }
  @media (min-width: 768px) {
    .hero-svg--desktop {
      display: block;
      /* Shift the visible area to the right half */
      -webkit-mask-image: linear-gradient(to right, transparent 5%, rgba(0,0,0,0.05) 20%, rgba(0,0,0,0.4) 45%, black 65%);
      mask-image: linear-gradient(to right, transparent 5%, rgba(0,0,0,0.05) 20%, rgba(0,0,0,0.4) 45%, black 65%);
    }
    .hero-svg--mobile {
      display: none;
    }
  }

  /* Mobile: visible but faded toward left/top to protect text */
  .hero-svg--mobile {
    display: block;
    -webkit-mask-image: linear-gradient(to bottom, transparent 5%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.6) 60%, transparent 95%);
    mask-image: linear-gradient(to bottom, transparent 5%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.6) 60%, transparent 95%);
  }

  /* Pulse animations */
  .pulse-d {
    stroke-dasharray: 120 2200;
    stroke-dashoffset: 2200;
    stroke-linecap: round;
  }
  .pulse-m {
    stroke-dasharray: 90 800;
    stroke-dashoffset: 800;
    stroke-linecap: round;
  }

  @media (prefers-reduced-motion: no-preference) {
    .pulse-d-1 { animation: flow-d 9s linear infinite 0s; }
    .pulse-d-2 { animation: flow-d 11s linear infinite 2.5s; }
    .pulse-d-3 { animation: flow-d 10s linear infinite 1s; }
    .pulse-m-1 { animation: flow-m 7s linear infinite 0s; }
    .pulse-m-2 { animation: flow-m 9s linear infinite 2s; }
  }

  @keyframes flow-d {
    0%   { stroke-dashoffset: 2200; }
    100% { stroke-dashoffset: 0; }
  }
  @keyframes flow-m {
    0%   { stroke-dashoffset: 800; }
    100% { stroke-dashoffset: 0; }
  }
</style>
