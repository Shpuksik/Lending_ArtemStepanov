---
import Button from '../ui/Button.astro';

---

<header class="w-full relative z-50">
  <div class="py-4 md:py-6 w-full max-w-[1200px] mx-auto px-5 lg:px-8 flex items-center justify-between">
    <div class="text-xl md:text-2xl font-semibold tracking-tight text-text-main">
      Артём Степанов
    </div>
    <Button href="#contacts" variant="secondary" class="hidden md:inline-flex px-4 min-h-[40px] text-sm">
      Связаться
    </Button>
  </div>
</header>
