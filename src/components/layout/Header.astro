---
import Button from '../ui/Button.astro';
import { contacts } from '../../config/content';
---

<header class="py-4 md:py-6 w-full max-w-[1200px] mx-auto px-5 lg:px-8 flex items-center justify-between z-50 lg:sticky lg:top-0 bg-bg/90 backdrop-blur-sm">
  <div class="text-xl md:text-2xl font-semibold tracking-tight text-text-main">
    Артём Степанов
  </div>
  <Button href={contacts.telegram} variant="secondary" class="hidden md:inline-flex px-4 min-h-[40px] text-sm">
    Связаться
  </Button>
</header>
